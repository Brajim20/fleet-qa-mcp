# Copy to .env and fill in. .env is gitignored — never commit real values.
# Everything here is OPTIONAL: by default the server reads your existing
# ~/.fleet/config (the file `fleetctl` writes) for the instance URL + token.

# --- Instance (override ~/.fleet/config only if you need to) ---
# FLEET_URL=https://localhost:8080
# FLEET_TOKEN=                      # admin API token; else taken from ~/.fleet/config
# FLEET_CONTEXT=default             # which ~/.fleet/config context to use

# --- Token auto-refresh (re-login on 401) ---
# Set a password to auto-recover from the ~hourly token expiry. Email comes
# from ~/.fleet/config unless FLEET_EMAIL is set. Never committed (.env is ignored).
# FLEET_EMAIL=you@example.com
# FLEET_PASSWORD=

# --- Fleet source for code tools (git show <rev>:<path>, merge-base) ---
# Point at the Fleet checkout your build comes from. If unset, the server
# self-provisions a managed clone of fleetdm/fleet under ./.fleet-src.
# FLEET_REPO=/Users/you/Documents/GitHub/fleet

# --- GitHub (for reading issues/PRs; prefilled issue URLs need no token) ---
# GITHUB_TOKEN=

# --- Device tokens (for /device/{token}/... endpoints) ---
# Not resolvable via admin API. Grab from the My Device page network tab and
# pass per-call, or set one here for convenience during a session.
# FLEET_DEVICE_TOKEN=
